		"@sanity/vision": "^5.13.0",
		"@vercel/analytics": "^1.6.1",
		"babel-plugin-react-compiler": "^1.0.0",
		"clsx": "^2.1.1",
		"next": "16.1.6",
		"next-sanity": "^12.1.0",
		"nuqs": "^2.8.9",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-icons": "^5.6.0",
